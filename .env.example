# FILE: .env.example
# VERSION: 1.0.1
# START_MODULE_CONTRACT
#   PURPOSE: Document local development environment variables for the template stack.
#   SCOPE: Covers developer defaults for PostgreSQL, Redis, API, admin bootstrap/session auth, web-admin, and public web; excludes production secrets.
#   DEPENDS: docker/docker-compose.dev.yml, apps/api/config/config.yml, apps/web-admin/src/shared/config/index.ts, apps/web/src/shared/config.ts.
#   LINKS: M-WORKSPACE / M-API / M-WEB-ADMIN / M-WEB / VF-LOCAL-DEV.
#   ROLE: CONFIG
#   MAP_MODE: SUMMARY
# END_MODULE_CONTRACT
# START_MODULE_MAP
#   PostgreSQL - Local dev database connection defaults.
#   Redis - Local dev cache connection defaults.
#   Go API - Local API bind and CORS defaults.
#   Admin Auth - Local first-admin bootstrap and session examples.
#   Web Admin - Vite admin GraphQL browser config defaults.
#   Public Web - Next runtime REST proxy config defaults.
# END_MODULE_MAP
# START_CHANGE_SUMMARY
#   LAST_CHANGE: 1.0.2 - Replaced placeholder bearer auth env with admin bootstrap and session examples.
# END_CHANGE_SUMMARY

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=7501
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=monorepo_dev
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=7502
REDIS_PASSWORD=

# Go API
SERVER_PORT=8090
SERVER_ENV=development
SERVER_CORS_ORIGINS=http://localhost:3100,http://localhost:3101
LOG_LEVEL=debug

# Admin bootstrap and session auth
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=ChangeMeAdmin123!
ADMIN_INITIAL_NAME=Template Admin
ADMIN_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
ADMIN_SESSION_COOKIE_NAME=web_admin_session
ADMIN_SESSION_TTL=168h
ADMIN_SESSION_COOKIE_SECURE=auto
ADMIN_SESSION_SAME_SITE=Lax
ADMIN_SESSION_KEY_SECRET=change-me-session-key-secret

# Web Admin (Vite browser config, dev server :3100)
VITE_GRAPHQL_API_URL=http://localhost:8090/graphql
VITE_APP_NAME=MonorepoApp

# Public Web (Next runtime config, dev server :3101)
WEB_API_BASE_URL=http://localhost:8090
