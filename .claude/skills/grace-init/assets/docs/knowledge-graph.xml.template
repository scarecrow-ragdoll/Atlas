    <!-- Module declarations use unique ID-based tags.
         Each module gets a unique ID prefix (e.g., M-CONFIG, M-DB, M-AUTH).

         Example:
         <M-CONFIG NAME="Config" TYPE="UTILITY" STATUS="planned">
            <purpose>Application configuration and environment management</purpose>
            <path>src/config/index.ts</path>
            <depends>none</depends>
            <verification-ref>V-M-CONFIG</verification-ref>
             <annotations>
               <!-- Public interface only. Keep private helpers and internal-only types in the source file header instead of shared docs. -->
               <fn-loadConfig PURPOSE="Load and validate config from environment" />
               <type-AppConfig PURPOSE="Configuration type definition" />
               <export-config PURPOSE="Singleton config instance" />
            </annotations>
          </M-CONFIG>

          Module types: ENTRY_POINT, CORE_LOGIC, DATA_LAYER, UI_COMPONENT, UTILITY, INTEGRATION

          CrossLinks connect dependent modules:
          <CrossLink from="M-SOURCE" to="M-TARGET" relation="description" />

          Keep this file focused on module boundaries and public interfaces. Do not mirror every private helper from implementation files.

          STATUS should usually be one of: planned, partial, implemented
     -->

  </Project>
</KnowledgeGraph>
