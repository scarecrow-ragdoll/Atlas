{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": ["scope:web"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bun run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bun run dev"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bun run test"
      }
    },
    "test-coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bun run test:coverage"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bunx eslint . --ext .ts,.tsx"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bun run typecheck"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web && bunx playwright test --config e2e/playwright.config.ts"
      }
    }
  }
}
