{
  "name": "web-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-admin/src",
  "projectType": "application",
  "tags": ["scope:web-admin"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run build"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run dev"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run test"
      }
    },
    "test-coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run test:coverage"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bunx eslint . --ext .ts,.tsx"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run typecheck"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bun run codegen"
      },
      "dependsOn": ["^validate"]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd apps/web-admin && bunx playwright test --config e2e/playwright.config.ts"
      }
    }
  }
}
